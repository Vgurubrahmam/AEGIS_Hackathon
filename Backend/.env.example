# ============================================
# AEGIS Backend — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Groq API (required — powers all LLM agents)
GROQ_API_KEY=

# Twilio SMS (optional — falls back to logging-only mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Maps Geocoding API (optional — falls back to landmark table only)
GOOGLE_MAPS_API_KEY=

# Database (default: SQLite file in project root)
DATABASE_URL=sqlite+aiosqlite:///./aegis.db

# Pipeline Configuration
CONFIDENCE_THRESHOLD=0.6

# Demo city for landmark seeding (used in seed.py)
DEMO_CITY=Hyderabad
